<?xml version="1.0" encoding="UTF-8"?>
<!--
  Example_FareModelling.xml

  Demonstrates a complete fare model for a simple single ticket:
  - TariffZone attached to StopPlaces
  - Tariff, ValidableElement, PreassignedFareProduct in FareFrame
  - SalesOfferPackage with adult and child variants
  - FareContract representing an actual purchase in SalesTransactionFrame

  Scenario:
  Zone 1 (Oslo) and Zone 2 (Drammen).
  Single ticket product sold as adult (42 NOK) and child (21 NOK).
  One purchase transaction in the sales frame.
-->
<PublicationDelivery xmlns="http://www.netex.org.uk/netex" version="2.0">
  <PublicationTimestamp>2026-03-18T00:00:00Z</PublicationTimestamp>
  <ParticipantRef>NP</ParticipantRef>
  <dataObjects>
    <CompositeFrame id="NP:CompositeFrame:Fares:1" version="1">
      <codespaces>
        <Codespace id="np">
          <Xmlns>NP</Xmlns>
          <XmlnsUrl>http://www.nordicprofile.eu/ns/np</XmlnsUrl>
        </Codespace>
      </codespaces>
      <FrameDefaults>
        <DefaultCodespaceRef ref="np"/>
      </FrameDefaults>
      <frames>

        <!-- ============================================================
             SITE FRAME — TariffZones and StopPlaces
             ============================================================ -->
        <SiteFrame id="NP:SiteFrame:Fares:1" version="1">
          <stopPlaces>
            <StopPlace id="NP:StopPlace:OsloS" version="1">
              <Name>Oslo S</Name>
              <TransportMode>rail</TransportMode>
              <StopPlaceType>railStation</StopPlaceType>
            </StopPlace>
            <StopPlace id="NP:StopPlace:Drammen" version="1">
              <Name>Drammen stasjon</Name>
              <TransportMode>rail</TransportMode>
              <StopPlaceType>railStation</StopPlaceType>
            </StopPlace>
          </stopPlaces>
          <tariffZones>
            <TariffZone id="NP:TariffZone:Zone1" version="1">
              <Name>Zone 1 - Oslo</Name>
            </TariffZone>
            <TariffZone id="NP:TariffZone:Zone2" version="1">
              <Name>Zone 2 - Drammen</Name>
            </TariffZone>
          </tariffZones>
        </SiteFrame>

        <!-- ============================================================
             FARE FRAME — Product catalogue
             ============================================================ -->
        <FareFrame id="NP:FareFrame:1" version="1">
          <!-- Pricing rules -->
          <tariffs>
            <Tariff id="NP:Tariff:ZoneTariff" version="1">
              <Name>Standard zone tariff</Name>
            </Tariff>
          </tariffs>

          <!-- What the passenger can travel on -->
          <validableElements>
            <ValidableElement id="NP:ValidableElement:SingleZone1" version="1">
              <Name>Single journey within Zone 1</Name>
            </ValidableElement>
            <ValidableElement id="NP:ValidableElement:SingleZone1_2" version="1">
              <Name>Single journey Zone 1 to Zone 2</Name>
            </ValidableElement>
          </validableElements>

          <!-- Named product: access right + tariff -->
          <fareProducts>
            <PreassignedFareProduct id="NP:PreassignedFareProduct:SingleTicket" version="1">
              <Name>Single ticket</Name>
              <accessRightsInProduct>
                <AccessRightInProduct id="NP:AccessRightInProduct:1" version="1">
                  <ValidableElementRef ref="NP:ValidableElement:SingleZone1" version="1"/>
                </AccessRightInProduct>
              </accessRightsInProduct>
              <tariffs>
                <TariffRef ref="NP:Tariff:ZoneTariff" version="1"/>
              </tariffs>
            </PreassignedFareProduct>
          </fareProducts>

          <!-- How the product is sold (adult and child variants) -->
          <salesOfferPackages>
            <SalesOfferPackage id="NP:SalesOfferPackage:SingleAdult" version="1">
              <Name>Single ticket - Adult</Name>
              <salesOfferPackageElements>
                <SalesOfferPackageElement id="NP:SalesOfferPackageElement:Adult_1" version="1" order="1">
                  <PreassignedFareProductRef ref="NP:PreassignedFareProduct:SingleTicket" version="1"/>
                </SalesOfferPackageElement>
              </salesOfferPackageElements>
            </SalesOfferPackage>
            <SalesOfferPackage id="NP:SalesOfferPackage:SingleChild" version="1">
              <Name>Single ticket - Child</Name>
              <salesOfferPackageElements>
                <SalesOfferPackageElement id="NP:SalesOfferPackageElement:Child_1" version="1" order="1">
                  <PreassignedFareProductRef ref="NP:PreassignedFareProduct:SingleTicket" version="1"/>
                </SalesOfferPackageElement>
              </salesOfferPackageElements>
            </SalesOfferPackage>
          </salesOfferPackages>
        </FareFrame>

        <!-- ============================================================
             SALES TRANSACTION FRAME — Actual purchases
             ============================================================ -->
        <SalesTransactionFrame id="NP:SalesTransactionFrame:1" version="1">
          <fareContracts>
            <FareContract id="NP:FareContract:FC_001" version="1">
              <Name>Single ticket purchase</Name>
              <StartDate>2026-03-18T08:00:00Z</StartDate>
              <EndDate>2026-03-18T09:30:00Z</EndDate>
              <fareContractEntries>
                <SalesTransaction id="NP:SalesTransaction:ST_001" version="1">
                  <Name>Purchase via mobile app</Name>
                  <Amount>42.00</Amount>
                  <Currency>NOK</Currency>
                  <PaymentMethod>mobileApp</PaymentMethod>
                </SalesTransaction>
              </fareContractEntries>
            </FareContract>
          </fareContracts>
        </SalesTransactionFrame>

      </frames>
    </CompositeFrame>
  </dataObjects>
</PublicationDelivery>

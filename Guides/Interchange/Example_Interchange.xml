<?xml version="1.0" encoding="UTF-8"?>
<!--
  Example_Interchange.xml

  Demonstrates planned interchanges between ServiceJourneys, including:
  - A guaranteed interchange with timing constraints (bus to train at Asker)
  - A non-guaranteed interchange (train to local bus at Drammen)
  - An interchangeOnly stop (bus stops at Asker only for transfers)

  Scenario:
    Bus 100 runs Drammen -> Asker (stops at Asker only for train transfer)
    RE 10 runs Asker -> Oslo S (the guaranteed connection)
    Local Bus 200 runs from Drammen station (non-guaranteed connection)
-->
<PublicationDelivery xmlns="http://www.netex.org.uk/netex" version="2.0">
  <PublicationTimestamp>2026-03-18T00:00:00Z</PublicationTimestamp>
  <ParticipantRef>NP</ParticipantRef>
  <dataObjects>
    <CompositeFrame id="NP:CompositeFrame:Interchange:1" version="1">
      <codespaces>
        <Codespace id="np">
          <Xmlns>NP</Xmlns>
          <XmlnsUrl>http://www.nordicprofile.eu/ns/np</XmlnsUrl>
        </Codespace>
      </codespaces>
      <FrameDefaults>
        <DefaultCodespaceRef ref="np"/>
      </FrameDefaults>
      <frames>

        <!-- ============================================================
             SERVICE FRAME
             Stop points, routes, and journey patterns
             ============================================================ -->
        <ServiceFrame id="NP:ServiceFrame:Interchange:1" version="1">
          <scheduledStopPoints>
            <ScheduledStopPoint id="NP:ScheduledStopPoint:Drammen" version="1">
              <Name>Drammen stasjon</Name>
            </ScheduledStopPoint>
            <ScheduledStopPoint id="NP:ScheduledStopPoint:Asker" version="1">
              <Name>Asker stasjon</Name>
            </ScheduledStopPoint>
            <ScheduledStopPoint id="NP:ScheduledStopPoint:OsloS" version="1">
              <Name>Oslo S</Name>
            </ScheduledStopPoint>
          </scheduledStopPoints>

          <journeyPatterns>
            <!--
              Bus 100: Drammen -> Asker
              Note: Asker is interchangeOnly — the bus stops there
              solely to feed passengers to the train.
            -->
            <JourneyPattern id="NP:JourneyPattern:Bus100" version="1">
              <pointsInSequence>
                <StopPointInJourneyPattern id="NP:StopPointInJourneyPattern:Bus100_1" version="1" order="1">
                  <ScheduledStopPointRef ref="NP:ScheduledStopPoint:Drammen"/>
                  <ForAlighting>false</ForAlighting>
                  <ForBoarding>true</ForBoarding>
                </StopPointInJourneyPattern>
                <StopPointInJourneyPattern id="NP:StopPointInJourneyPattern:Bus100_2" version="1" order="2">
                  <ScheduledStopPointRef ref="NP:ScheduledStopPoint:Asker"/>
                  <ForAlighting>false</ForAlighting>
                  <ForBoarding>false</ForBoarding>
                  <!-- This stop exists only for the transfer to RE 10 -->
                  <StopUse>interchangeOnly</StopUse>
                </StopPointInJourneyPattern>
              </pointsInSequence>
            </JourneyPattern>

            <!-- RE 10: Asker -> Oslo S -->
            <JourneyPattern id="NP:JourneyPattern:RE10" version="1">
              <pointsInSequence>
                <StopPointInJourneyPattern id="NP:StopPointInJourneyPattern:RE10_1" version="1" order="1">
                  <ScheduledStopPointRef ref="NP:ScheduledStopPoint:Asker"/>
                  <ForAlighting>false</ForAlighting>
                  <ForBoarding>true</ForBoarding>
                </StopPointInJourneyPattern>
                <StopPointInJourneyPattern id="NP:StopPointInJourneyPattern:RE10_2" version="1" order="2">
                  <ScheduledStopPointRef ref="NP:ScheduledStopPoint:OsloS"/>
                  <ForAlighting>true</ForAlighting>
                  <ForBoarding>false</ForBoarding>
                </StopPointInJourneyPattern>
              </pointsInSequence>
            </JourneyPattern>
          </journeyPatterns>
        </ServiceFrame>

        <!-- ============================================================
             TIMETABLE FRAME
             ServiceJourneys and their interchanges
             ============================================================ -->
        <TimetableFrame id="NP:TimetableFrame:Interchange:1" version="1">
          <vehicleJourneys>
            <!-- Feeder: Bus 100 arriving at Asker -->
            <ServiceJourney id="NP:ServiceJourney:Bus100_0730" version="1">
              <Name>Bus 100 Drammen 07:30</Name>
              <JourneyPatternRef ref="NP:JourneyPattern:Bus100"/>
            </ServiceJourney>

            <!-- Distributor: RE 10 departing from Asker -->
            <ServiceJourney id="NP:ServiceJourney:RE10_0800" version="1">
              <Name>RE 10 Asker 08:00</Name>
              <JourneyPatternRef ref="NP:JourneyPattern:RE10"/>
            </ServiceJourney>

            <!-- Another journey from Drammen (for non-guaranteed interchange) -->
            <ServiceJourney id="NP:ServiceJourney:Bus200_0745" version="1">
              <Name>Bus 200 Drammen 07:45</Name>
            </ServiceJourney>
          </vehicleJourneys>

          <journeyInterchanges>
            <!--
              GUARANTEED INTERCHANGE: Bus 100 -> RE 10 at Asker
              The train will wait up to 10 minutes for the bus.
              Passengers need at least 3 minutes to transfer.
            -->
            <ServiceJourneyInterchange id="NP:ServiceJourneyInterchange:Bus100_to_RE10" version="1">
              <Guaranteed>true</Guaranteed>
              <MaximumWaitTime>PT10M</MaximumWaitTime>
              <MinimumTransferTime>PT3M</MinimumTransferTime>
              <FromPointRef ref="NP:ScheduledStopPoint:Asker"/>
              <ToPointRef ref="NP:ScheduledStopPoint:Asker"/>
              <FromJourneyRef ref="NP:ServiceJourney:Bus100_0730"/>
              <ToJourneyRef ref="NP:ServiceJourney:RE10_0800"/>
            </ServiceJourneyInterchange>

            <!--
              NON-GUARANTEED INTERCHANGE: Bus 100 -> Bus 200 at Drammen
              A possible transfer, but the local bus will not wait.
            -->
            <ServiceJourneyInterchange id="NP:ServiceJourneyInterchange:Bus100_to_Bus200" version="1">
              <Guaranteed>false</Guaranteed>
              <MinimumTransferTime>PT5M</MinimumTransferTime>
              <FromPointRef ref="NP:ScheduledStopPoint:Drammen"/>
              <ToPointRef ref="NP:ScheduledStopPoint:Drammen"/>
              <FromJourneyRef ref="NP:ServiceJourney:Bus100_0730"/>
              <ToJourneyRef ref="NP:ServiceJourney:Bus200_0745"/>
            </ServiceJourneyInterchange>
          </journeyInterchanges>
        </TimetableFrame>

      </frames>
    </CompositeFrame>
  </dataObjects>
</PublicationDelivery>

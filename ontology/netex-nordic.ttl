## -----------------------------------------------------------------
## NeTEx Nordic Profile Ontology
## -----------------------------------------------------------------
## Machine-readable profile model: classes, frames, relationships,
## cardinality constraints, and profile restrictions for the Nordic Profile (NP).
##
## This file is the PROFILE SCHEMA only. For documentation file paths,
## guides, and example references see netex-nordic-documentation.ttl.
##
## Generated: 2026-05-08
## -----------------------------------------------------------------

@prefix netex:   <https://netex-cen.eu/ontology#> .
@prefix profile: <https://netex-cen.eu/profile#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix tm-commons:  <https://w3id.org/transmodel/commons#> .
@prefix tm-journeys: <https://w3id.org/transmodel/journeys#> .
@prefix tm-fac:      <https://w3id.org/transmodel/facilities#> .
@prefix tm-org:      <https://w3id.org/transmodel/organisations#> .
@prefix tm-fares:    <https://w3id.org/transmodel/fares#> .

## =================================================================
## PROFILE
## =================================================================

profile:NP a netex:Profile ;
    rdfs:label "Nordic Profile" ;
    skos:notation "NP" .

## =================================================================
## DATA GOVERNANCE (NP)
## =================================================================
## In the Nordic Profile, all data is NeTEx but ownership is separated.
## Central registries are maintained by the coordinating authority (e.g. Entur).
## Operators produce NeTEx deliveries that REFERENCE objects in these registries.
## -----------------------------------------------------------------

netex:CentralRegistry a netex:DataSource ;
    rdfs:label "Central registry" ;
    skos:definition "Mastered in a shared national registry. Operators reference these objects by id but do not produce or version them." .

netex:OperatorDelivery a netex:DataSource ;
    rdfs:label "Operator delivery" ;
    skos:definition "Produced by operators in their NeTEx deliveries. May contain references to central registry objects." .

## --- NP data ownership per class ---
## Central registries (operator references these via @ref)

netex:StopPlace      netex:npDataSource netex:CentralRegistry .
netex:Quay           netex:npDataSource netex:CentralRegistry .
netex:TopographicPlace netex:npDataSource netex:CentralRegistry .
netex:Authority      netex:npDataSource netex:CentralRegistry .
netex:Operator       netex:npDataSource netex:CentralRegistry .
netex:TariffZone     netex:npDataSource netex:CentralRegistry .
netex:FareZone       netex:npDataSource netex:CentralRegistry .

## --- Operator-produced data (delivered to central system) ---

netex:Line               netex:npDataSource netex:OperatorDelivery .
netex:Route              netex:npDataSource netex:OperatorDelivery .
netex:JourneyPattern     netex:npDataSource netex:OperatorDelivery .
netex:ServiceJourney     netex:npDataSource netex:OperatorDelivery .
netex:DatedServiceJourney netex:npDataSource netex:OperatorDelivery .
netex:DayType            netex:npDataSource netex:OperatorDelivery .
netex:DayTypeAssignment  netex:npDataSource netex:OperatorDelivery .
netex:OperatingPeriod    netex:npDataSource netex:OperatorDelivery .
netex:OperatingDay       netex:npDataSource netex:OperatorDelivery .
netex:ScheduledStopPoint netex:npDataSource netex:OperatorDelivery .
netex:PassengerStopAssignment netex:npDataSource netex:OperatorDelivery .
netex:DestinationDisplay netex:npDataSource netex:OperatorDelivery .
netex:Notice             netex:npDataSource netex:OperatorDelivery .
netex:GroupOfLines       netex:npDataSource netex:OperatorDelivery .
netex:Interchange        netex:npDataSource netex:OperatorDelivery .
netex:TrainBlock         netex:npDataSource netex:OperatorDelivery .
netex:Vehicle            netex:npDataSource netex:OperatorDelivery .
netex:VehicleType        netex:npDataSource netex:OperatorDelivery .
netex:Codespace          netex:npDataSource netex:OperatorDelivery .

## =================================================================
## FRAME CLASSES (Containers)
## =================================================================

netex:CompositeFrame a owl:Class ;
    rdfs:label "CompositeFrame" ;
    skos:definition "Container frame grouping multiple frames into a single delivery" ;
    netex:contains netex:ResourceFrame ,
                   netex:SiteFrame ,
                   netex:ServiceCalendarFrame ,
                   netex:ServiceFrame ,
                   netex:TimetableFrame ,
                   netex:VehicleScheduleFrame ,
                   netex:FareFrame ,
                   netex:SalesTransactionFrame ;
    netex:contains netex:Codespace .

netex:ResourceFrame a owl:Class ;
    rdfs:label "ResourceFrame" ;
    skos:definition "Organizations, vehicle types, vehicles and shared resources" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:Authority ,
                   netex:Operator ,
                   netex:VehicleType ,
                   netex:Vehicle ,
                   netex:PurposeOfGrouping .

netex:SiteFrame a owl:Class ;
    rdfs:label "SiteFrame" ;
    skos:definition "Stop places, topographic places, parking, and tariff zones" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:StopPlace ,
                   netex:TopographicPlace ,
                   netex:Parking ,
                   netex:TariffZone .

netex:ServiceCalendarFrame a owl:Class ;
    rdfs:label "ServiceCalendarFrame" ;
    skos:definition "Day types, operating periods, and calendar assignments" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:DayType ,
                   netex:DayTypeAssignment ,
                   netex:OperatingPeriod ,
                   netex:OperatingDay .

netex:ServiceFrame a owl:Class ;
    rdfs:label "ServiceFrame" ;
    skos:definition "Lines, routes, journey patterns, stop points, and assignments" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:Line ,
                   netex:Route ,
                   netex:JourneyPattern ,
                   netex:ScheduledStopPoint ,
                   netex:PassengerStopAssignment ,
                   netex:DestinationDisplay ,
                   netex:GroupOfLines ,
                   netex:Notice ,
                   netex:FlexibleServiceProperties .

netex:TimetableFrame a owl:Class ;
    rdfs:label "TimetableFrame" ;
    skos:definition "Service journeys, dated journeys, and interchange rules" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:ServiceJourney ,
                   netex:DatedServiceJourney ,
                   netex:Interchange .

netex:VehicleScheduleFrame a owl:Class ;
    rdfs:label "VehicleScheduleFrame" ;
    skos:definition "Vehicle blocks and scheduling assignments" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:TrainBlock .

netex:FareFrame a owl:Class ;
    rdfs:label "FareFrame" ;
    skos:definition "Fares, tariffs, fare products, and sales offer packages" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:FareZone .

netex:SalesTransactionFrame a owl:Class ;
    rdfs:label "SalesTransactionFrame" ;
    skos:definition "Sales transaction data and fare contracts" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:FareContract .

## =================================================================
## OBJECT CLASSES
## =================================================================

## -----------------------------------------------------------------
## ResourceFrame objects
## -----------------------------------------------------------------

netex:Authority a owl:Class ;
    rdfs:label "Authority" ;
    skos:definition "Transit authority — the public body responsible for organizing transport" ;
    netex:inFrame netex:ResourceFrame .

netex:Operator a owl:Class ;
    rdfs:label "Operator" ;
    skos:definition "Transport operator — the company running the services" ;
    netex:inFrame netex:ResourceFrame .

netex:VehicleType a owl:Class ;
    rdfs:label "VehicleType" ;
    skos:definition "Vehicle classification with capacity and propulsion characteristics" ;
    netex:inFrame netex:ResourceFrame .

netex:Vehicle a owl:Class ;
    rdfs:label "Vehicle" ;
    skos:definition "Individual rolling stock unit assigned to an operator" ;
    netex:inFrame netex:ResourceFrame .

netex:PurposeOfGrouping a owl:Class ;
    rdfs:label "PurposeOfGrouping" ;
    skos:definition "Classification of why objects are grouped together" ;
    netex:inFrame netex:ResourceFrame .

netex:ResponsibilitySet a owl:Class ;
    rdfs:label "ResponsibilitySet" ;
    skos:definition "Set of responsibility role assignments linking organizations to domains" ;
    netex:inFrame netex:ResourceFrame .

netex:Contract a owl:Class ;
    rdfs:label "Contract" ;
    skos:definition "Agreement between authority and operator for service provision" ;
    netex:inFrame netex:ResourceFrame .

## -----------------------------------------------------------------
## SiteFrame objects
## -----------------------------------------------------------------

netex:StopPlace a owl:Class ;
    rdfs:label "StopPlace" ;
    skos:definition "Physical stop location containing one or more quays" ;
    netex:inFrame netex:SiteFrame .

netex:Quay a owl:Class ;
    rdfs:label "Quay" ;
    skos:definition "Boarding/alighting point within a StopPlace" ;
    netex:childOf netex:StopPlace .

netex:TopographicPlace a owl:Class ;
    rdfs:label "TopographicPlace" ;
    skos:definition "Named geographic area (city, municipality, county)" ;
    netex:inFrame netex:SiteFrame .

netex:Parking a owl:Class ;
    rdfs:label "Parking" ;
    skos:definition "Parking facility, typically associated with a StopPlace" ;
    netex:inFrame netex:SiteFrame .

netex:TariffZone a owl:Class ;
    rdfs:label "TariffZone" ;
    skos:definition "Geographic zone used for fare calculation" ;
    netex:inFrame netex:SiteFrame .

netex:FareZone a owl:Class ;
    rdfs:label "FareZone" ;
    skos:definition "Zone defining fare boundaries, may contain scheduled stop points" ;
    netex:inFrame netex:FareFrame .

## -----------------------------------------------------------------
## Equipment objects (children of StopPlace/Quay)
## -----------------------------------------------------------------

netex:ShelterEquipment a owl:Class ;
    rdfs:label "ShelterEquipment" ;
    skos:definition "Waiting shelter at a stop" ;
    netex:childOf netex:StopPlace , netex:Quay .

netex:WaitingRoomEquipment a owl:Class ;
    rdfs:label "WaitingRoomEquipment" ;
    skos:definition "Waiting room facility at a stop" ;
    netex:childOf netex:StopPlace , netex:Quay .

netex:SanitaryEquipment a owl:Class ;
    rdfs:label "SanitaryEquipment" ;
    skos:definition "Sanitary facilities at a stop" ;
    netex:childOf netex:StopPlace , netex:Quay .

netex:TicketingEquipment a owl:Class ;
    rdfs:label "TicketingEquipment" ;
    skos:definition "Ticketing machines and validation equipment" ;
    netex:childOf netex:StopPlace , netex:Quay .

## -----------------------------------------------------------------
## ServiceCalendarFrame objects
## -----------------------------------------------------------------

netex:DayType a owl:Class ;
    rdfs:label "DayType" ;
    skos:definition "Abstract day classification (weekday, holiday, etc.)" ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:DayTypeAssignment a owl:Class ;
    rdfs:label "DayTypeAssignment" ;
    skos:definition "Binds a DayType to a specific date or OperatingPeriod" ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:OperatingPeriod a owl:Class ;
    rdfs:label "OperatingPeriod" ;
    skos:definition "Date range (FromDate–ToDate) for recurring service" ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:OperatingDay a owl:Class ;
    rdfs:label "OperatingDay" ;
    skos:definition "Specific calendar date for DatedServiceJourney instances" ;
    netex:inFrame netex:ServiceCalendarFrame .

## -----------------------------------------------------------------
## ServiceFrame objects
## -----------------------------------------------------------------

netex:Line a owl:Class ;
    rdfs:label "Line" ;
    skos:definition "Public transport service line grouping routes and journeys" ;
    netex:inFrame netex:ServiceFrame .

netex:GroupOfLines a owl:Class ;
    rdfs:label "GroupOfLines" ;
    skos:definition "Logical grouping of lines (e.g. by area or mode)" ;
    netex:inFrame netex:ServiceFrame .

netex:Route a owl:Class ;
    rdfs:label "Route" ;
    skos:definition "Ordered sequence of points defining a path for a line" ;
    netex:inFrame netex:ServiceFrame .

netex:JourneyPattern a owl:Class ;
    rdfs:label "JourneyPattern" ;
    skos:definition "Ordered sequence of stop points defining where a journey calls" ;
    netex:inFrame netex:ServiceFrame .

netex:StopPointInJourneyPattern a owl:Class ;
    rdfs:label "StopPointInJourneyPattern" ;
    skos:definition "A stop point's role within a journey pattern (order, boarding rules)" ;
    netex:childOf netex:JourneyPattern .

netex:ScheduledStopPoint a owl:Class ;
    rdfs:label "ScheduledStopPoint" ;
    skos:definition "Logical stop point in the timetable, linked to physical StopPlace via assignment" ;
    netex:inFrame netex:ServiceFrame .

netex:PassengerStopAssignment a owl:Class ;
    rdfs:label "PassengerStopAssignment" ;
    skos:definition "Bridge linking a logical ScheduledStopPoint to a physical StopPlace/Quay" ;
    netex:inFrame netex:ServiceFrame .

netex:DestinationDisplay a owl:Class ;
    rdfs:label "DestinationDisplay" ;
    skos:definition "Text shown to passengers on displays and signs" ;
    netex:inFrame netex:ServiceFrame .

netex:Notice a owl:Class ;
    rdfs:label "Notice" ;
    skos:definition "Informational text attached to journeys or stop points" ;
    netex:inFrame netex:ServiceFrame .

netex:FlexibleServiceProperties a owl:Class ;
    rdfs:label "FlexibleServiceProperties" ;
    skos:definition "Booking and flexibility rules for demand-responsive transport" ;
    netex:inFrame netex:ServiceFrame .

netex:LinkSequenceProjection a owl:Class ;
    rdfs:label "LinkSequenceProjection" ;
    skos:definition "GML geometry projecting a route or link onto a map" ;
    netex:inFrame netex:ServiceFrame .

## -----------------------------------------------------------------
## TimetableFrame objects
## -----------------------------------------------------------------

netex:ServiceJourney a owl:Class ;
    rdfs:label "ServiceJourney" ;
    skos:definition "A planned trip template in the timetable, reusable across dates" ;
    netex:inFrame netex:TimetableFrame .

netex:DatedServiceJourney a owl:Class ;
    rdfs:label "DatedServiceJourney" ;
    skos:definition "A concrete journey instance on a specific date, possibly with alterations" ;
    netex:inFrame netex:TimetableFrame ;
    netex:specializes netex:ServiceJourney .

netex:Interchange a owl:Class ;
    rdfs:label "Interchange" ;
    skos:definition "Planned transfer between two service journeys at stop points" ;
    netex:inFrame netex:TimetableFrame .

## -----------------------------------------------------------------
## VehicleScheduleFrame objects
## -----------------------------------------------------------------

netex:TrainBlock a owl:Class ;
    rdfs:label "TrainBlock" ;
    skos:definition "Block of journeys assigned to a single vehicle" ;
    netex:inFrame netex:VehicleScheduleFrame .

## -----------------------------------------------------------------
## SalesTransactionFrame objects
## -----------------------------------------------------------------

netex:FareContract a owl:Class ;
    rdfs:label "FareContract" ;
    skos:definition "A fare contract with entries representing purchased products" ;
    netex:inFrame netex:SalesTransactionFrame .

## -----------------------------------------------------------------
## Metadata objects (not frame-specific)
## -----------------------------------------------------------------

netex:AlternativeName a owl:Class ;
    rdfs:label "AlternativeName" ;
    skos:definition "Alternative name for any object (alias, translation, etc.)" .

netex:AlternativeText a owl:Class ;
    rdfs:label "AlternativeText" ;
    skos:definition "Alternative text representation for multilingual content" .

netex:Codespace a owl:Class ;
    rdfs:label "Codespace" ;
    skos:definition "XML namespace mapping (Xmlns ↔ XmlnsUrl) used in ID prefixes" .

netex:Network a owl:Class ;
    rdfs:label "Network" ;
    skos:definition "Top-level grouping of lines for an authority/operator" ;
    netex:inFrame netex:ServiceFrame .

## =================================================================
## ELEMENT ORDERING (XSD-derived)
## =================================================================
## Canonical element sequence per class, derived from XSD type
## hierarchy. Tables, descriptions, and generators should follow
## this order. Attributes (@id, @version, @order) are listed first
## by convention — XML attributes have no sequence constraint.
## Only elements documented in the profile Tables are listed.
## -----------------------------------------------------------------

netex:ServiceJourney netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "keyList"
] , [
    netex:position 4 ; netex:element "Name"
] , [
    netex:position 5 ; netex:element "PrivateCode"
] , [
    netex:position 6 ; netex:element "Description"
] , [
    netex:position 7 ; netex:element "TransportMode"
] , [
    netex:position 8 ; netex:element "TransportSubmode"
] , [
    netex:position 9 ; netex:element "dayTypes"
] , [
    netex:position 10 ; netex:element "JourneyPatternRef"
] , [
    netex:position 11 ; netex:element "VehicleTypeRef"
] , [
    netex:position 12 ; netex:element "BlockRef"
] , [
    netex:position 13 ; netex:element "OperatorRef"
] , [
    netex:position 14 ; netex:element "LineRef"
] , [
    netex:position 15 ; netex:element "FlexibleLineRef"
] , [
    netex:position 16 ; netex:element "passingTimes"
] , [
    netex:position 17 ; netex:element "parts"
] .

